#!/system/bin/sh

PT="/tmp/production_tool"

# ── ADB settings ──────────────────────────────────────────────────────────────
setprop service.adb.tcp.port 5555
setprop persist.adb.tcp.port 5555
setprop persist.sys.usb.config mtp,adb
stop adbd
sleep 1
start adbd

# ── Wi-Fi client settings ──────────────────────────────────────────────────────
cp $PT/wpa_supplicant.conf /data/misc/wifi/wpa_supplicant.conf
chmod 660 /data/misc/wifi/wpa_supplicant.conf
chown system:wifi /data/misc/wifi/wpa_supplicant.conf
wpa_cli -p /data/misc/wifi/sockets -i wlan0 reconfigure
sleep 5

# ── Install MQTT bridge (persistent, survives USB removal) ────────────────────

# copy config and bridge script to /data/local (always writable)
cp $PT/config.json    /data/local/config.json
cp $PT/mqtt_bridge.py /data/local/mqtt_bridge.py
chmod 755 /data/local/mqtt_bridge.py

# make root filesystem writable so we can update init RC files
mount -o rw,remount /

# disable wisund (it holds /dev/ttyS1 and blocks our bridge)
cp $PT/wisund_disabled.rc /system/etc/init/wisund.rc

# disable ndeclite_agent (depends on wisund socket, not needed)
cp $PT/ndeclite_disabled.rc /system/etc/init/ndeclite_agent.rc

# spec 015: disable NextDrive cloud daemons (NDCloudDaemon/fms/.../transman).
# Their cloud endpoints are decommissioned, so they were just generating
# DNS-resolution storms and CPU jitter in the background. Each replaced
# .rc has `disabled` added; on-property restart/stop handlers are removed
# for safety against Android init's `restart <disabled>` behaviour.
if [ "${DISABLE_CLOUD:-1}" = "1" ]; then
    for d in NDCloudDaemon fms fmssecman iijschedule rds sessiond transman; do
        if [ -f "$PT/cloud_disabled/${d}.rc" ]; then
            cp "$PT/cloud_disabled/${d}.rc" "/system/etc/init/${d}.rc"
        fi
    done
fi

# spec 015: repoint tlsdate to a public HTTPS host. The default host
# points at NextDrive infrastructure that is no longer reachable, so
# the daemon could not sync the clock anymore. www.google.com is
# broadly reachable and the local /etc/ssl/certs bundle includes the
# necessary root CAs.
if [ "${REPOINT_TLSDATE:-1}" = "1" ]; then
    if [ -f "$PT/tlsdated_timesync.rc" ]; then
        cp "$PT/tlsdated_timesync.rc" /system/etc/init/tlsdated.rc
    fi
fi

# install our MQTT bridge as an init service (auto-start on next boot)
cp $PT/mqtt_ha_bridge.rc /system/etc/init/mqtt_ha_bridge.rc

# ── Stop conflicting services immediately ──────────────────────────────────────
stop wisund
stop NDEcLiteAgent

# spec 015: stop cloud daemons immediately. They will stay stopped after
# reboot via the `disabled` keyword in the replaced .rc files above.
if [ "${DISABLE_CLOUD:-1}" = "1" ]; then
    for d in NDCloudDaemon fms fmssecman iijschedule rds sessiond transman; do
        stop "$d" 2>/dev/null || true
    done
fi

# spec 015: restart tlsdated so the new -H www.google.com argument
# takes effect without waiting for a reboot.
if [ "${REPOINT_TLSDATE:-1}" = "1" ]; then
    stop tlsdated 2>/dev/null || true
    sleep 1
    start tlsdated
fi
sleep 2

# ── Start MQTT bridge immediately via init (survives USB removal and reboot) ───
stop mqtt_ha_bridge 2>/dev/null || true
sleep 1
start mqtt_ha_bridge

# ── Finish LED (blink white) ───────────────────────────────────────────────
cp $PT/led_effect.sh /data/local/led_effect.sh
chmod 755 /data/local/led_effect.sh
/data/local/led_effect.sh blink white 10
